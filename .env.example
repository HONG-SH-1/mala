# MALA — 환경 변수 예시 (Phase 1 구현 시 사용)
# cp .env.example .env 후 수정

# GPU
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=4096

# 추론 (ADR-001: Ollama 우선)
INFERENCE_ENGINE=ollama
OLLAMA_MODEL=qwen3:8b
# INFERENCE_ENGINE=vllm
# VLLM_MODEL_PATH=/models/Qwen3-8B-Instruct

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
TASK_QUEUE=task_queue
RESULT_QUEUE=result_queue

# Obsidian (Phase 3)
OBSIDIAN_VAULT_PATH=D:/path/to/vault

# LangGraph
GRAPH_MAX_RETRIES=2
