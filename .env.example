# MALA — 환경 변수 예시
# copy .env.example .env  (Windows: copy .env.example .env)

# GPU (Phase 1+ reference; Ollama manages VRAM)
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=4096

# 추론 (ADR-001: Ollama on Windows host)
INFERENCE_ENGINE=ollama
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SEC=120

# Redis (ADR-002: Native Redis — ADR-001 docker optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
TASK_QUEUE=task_queue
RESULT_QUEUE=result_queue
PROCESSING_QUEUE=mala:processing:worker_1
DEAD_LETTER_QUEUE=mala:dead_letter_queue
WORKER_ID=worker_1

# Obsidian / RAG (Phase 3)
OBSIDIAN_VAULT_PATH=vault_sample
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=mala_vault
INDEX_MANIFEST_PATH=data/index_manifest.json
INDEX_FAILURES_PATH=data/index_failures.jsonl
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=5

# LangGraph (Phase 2)
GRAPH_MAX_RETRIES=2
TASK_STATUS_PREFIX=task_status
